# Local/disposable Phase 06 inventory database only. Copy to
# .env.inventory-test; never commit the copied file.
# The preflight validates every identity field without opening a connection.
NODE_ENV=test
APPLE333_INVENTORY_TEST_DB=1

# These values are deliberately fixed. Do not point this file to a shared,
# development, staging, or production database, role, hostname, or port.
INVENTORY_TEST_POSTGRES_DB=apple333_inventory_test
INVENTORY_TEST_POSTGRES_USER=apple333_inventory_test
INVENTORY_TEST_POSTGRES_PASSWORD=local-test-only-change-me
INVENTORY_TEST_POSTGRES_BIND=127.0.0.1
INVENTORY_TEST_POSTGRES_PORT=55433

# Must exactly target the database and role above through literal IPv4 loopback
# on port 55433 with schema=public. URL-encode reserved password characters.
INVENTORY_TEST_DATABASE_URL=postgresql://apple333_inventory_test:local-test-only-change-me@127.0.0.1:55433/apple333_inventory_test?schema=public
