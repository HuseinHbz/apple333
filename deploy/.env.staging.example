# Apple333 isolated staging configuration template.
#
# Copy this file to a protected location OUTSIDE the repository, for example:
#   /etc/apple333/staging.env
# Then set mode 0600 and replace every placeholder through the staging secret
# manager. Never copy production values, export this file into CI logs, or
# commit a populated staging environment file.

# Deployment identity. This project and install ID must never be shared with
# production. Leave the install ID empty only while preparing the template; a
# future reviewed installer must generate and record a unique staging value.
APPLE333_PROJECT_ID=apple333-enterprise-platform
APPLE333_ENVIRONMENT=staging
COMPOSE_PROJECT_NAME=apple333-staging
APPLE333_INSTALL_ROOT=/opt/apple333-staging
APPLE333_STATE_DIR=/var/lib/apple333-staging
APPLE333_BACKUP_DIR=/var/lib/apple333-staging/backups
APPLE333_INSTALL_ID=

# The staging nginx container is loopback-only. A separately reviewed TLS edge
# may forward staging.apple333.ir to this unique port.
APPLE333_HTTP_BIND=127.0.0.1
APPLE333_HTTP_PORT=8081

# NODE_ENV=production is the Next.js runtime mode, not the deployment target.
NODE_ENV=production
APP_NAME=Apple333 Staging
APP_URL=https://staging.apple333.ir
AUTH_URL=https://staging.apple333.ir
NEXTAUTH_URL=https://staging.apple333.ir
AUTH_SECRET=replace-with-a-long-unique-staging-auth-secret
NEXTAUTH_SECRET=replace-with-a-long-unique-staging-auth-secret
APPLE333_APP_IMAGE=apple333/app:staging

# Managed staging PostgreSQL. Use only the internal Compose hostname and the
# dedicated database/schema below; public/shared database targets are forbidden.
POSTGRES_DB=apple333_staging
POSTGRES_SCHEMA=apple333_staging
POSTGRES_USER=apple333_staging
POSTGRES_PASSWORD=replace-with-a-long-unique-staging-postgres-password
DATABASE_URL=postgresql://apple333_staging:replace-with-a-long-unique-staging-postgres-password@postgres:5432/apple333_staging?schema=apple333_staging

# Managed staging Redis. It has a different secret and private data volume.
REDIS_PASSWORD=replace-with-a-long-unique-staging-redis-password
REDIS_URL=redis://:replace-with-a-long-unique-staging-redis-password@redis:6379

# Private staging object-storage foundation. The current application does not
# activate an S3 adapter or create buckets/users automatically.
MINIO_ROOT_USER=apple333-staging-minio-root
MINIO_ROOT_PASSWORD=replace-with-a-long-unique-staging-minio-password
APPLE333_MINIO_IMAGE=minio/minio:RELEASE.2024-10-13T13-34-11Z
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=apple333-staging
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional staging-only telemetry. Leave SENTRY_DSN empty until a separate
# staging project and PII policy are approved. Never use the production DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1
