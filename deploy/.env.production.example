# Copy this file to deploy/.env.production on the server, then set restrictive
# permissions: chmod 600 deploy/.env.production

# Ownership identity — do not reuse this compose project for another application.
APPLE333_PROJECT_ID=apple333-enterprise-platform
APPLE333_ENVIRONMENT=production
COMPOSE_PROJECT_NAME=apple333-production
APPLE333_INSTALL_ROOT=/opt/apple333
APPLE333_STATE_DIR=/var/lib/apple333
APPLE333_BACKUP_DIR=/var/lib/apple333/backups
# Leave empty on first install; install.sh generates a unique value.
APPLE333_INSTALL_ID=

# The managed deployment validator requires the bundled nginx to stay on
# loopback. Terminate TLS at the separately reviewed public edge.
APPLE333_HTTP_BIND=127.0.0.1
APPLE333_HTTP_PORT=8080

# Public application origin. Use HTTPS in production.
NODE_ENV=production
APP_NAME=Apple333
APP_URL=https://shop.example.com
AUTH_URL=https://shop.example.com
NEXTAUTH_URL=https://shop.example.com
# Recommended generator: openssl rand -hex 32
AUTH_SECRET=replace-with-a-random-secret-of-at-least-32-characters
NEXTAUTH_SECRET=replace-with-the-same-random-secret

# Managed PostgreSQL. The schema must be dedicated to Apple333; do not use
# public on a shared database. URL-encode reserved password characters in
# DATABASE_URL.
POSTGRES_DB=apple333
POSTGRES_SCHEMA=apple333
POSTGRES_USER=apple333
# Use a shell-safe secret, for example: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-unique-password
DATABASE_URL=postgresql://apple333:replace-with-a-long-unique-password@postgres:5432/apple333?schema=apple333

# Redis is private, authenticated, and required in production.
REDIS_PASSWORD=replace-with-a-long-unique-redis-password
REDIS_URL=redis://:replace-with-a-long-unique-redis-password@redis:6379

# MinIO infrastructure foundation. It is private and does not automatically
# activate application media storage; see docs/phase-01 for the approval gate.
MINIO_ROOT_USER=apple333-minio-root
MINIO_ROOT_PASSWORD=replace-with-a-long-unique-minio-password
APPLE333_MINIO_IMAGE=minio/minio:RELEASE.2024-10-13T13-34-11Z

# Optional private Prometheus/Grafana profile: docker compose --profile observability
PROMETHEUS_RETENTION_TIME=15d
GRAFANA_HTTP_PORT=3001
GRAFANA_ADMIN_USER=apple333-observability
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-unique-grafana-password

# Encrypted PostgreSQL backup. Store the age private identity outside this
# checkout and keep the off-host path on separately managed encrypted storage.
APPLE333_BACKUP_AGE_RECIPIENT=age1replace-with-approved-public-recipient
APPLE333_BACKUP_AGE_IDENTITY_FILE=/etc/apple333/backup.agekey
APPLE333_BACKUP_OFFSITE_DIR=/mnt/apple333-backups/production
APPLE333_BACKUP_RETENTION_DAYS=35

# Optional observability/storage. Leave unset when not configured.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
