# Copy this file to deploy/.env.production on the server, then set restrictive
# permissions: chmod 600 deploy/.env.production

# Ownership identity — do not reuse this compose project for another application.
APPLE333_PROJECT_ID=apple333-enterprise-platform
APPLE333_ENVIRONMENT=production
COMPOSE_PROJECT_NAME=apple333-production
APPLE333_INSTALL_ROOT=/opt/apple333
APPLE333_STATE_DIR=/var/lib/apple333
APPLE333_BACKUP_DIR=/var/lib/apple333/backups
# Leave empty on first install; install.sh generates a unique value.
APPLE333_INSTALL_ID=

# Bind the bundled nginx only to loopback unless this server is intentionally
# exposed directly. Put TLS/reverse-proxy configuration in front of it.
APPLE333_HTTP_BIND=127.0.0.1
APPLE333_HTTP_PORT=8080

# Public application origin. Use HTTPS in production.
NODE_ENV=production
APP_NAME=Apple333
APP_URL=https://shop.example.com
AUTH_URL=https://shop.example.com
NEXTAUTH_URL=https://shop.example.com
# Recommended generator: openssl rand -hex 32
AUTH_SECRET=replace-with-a-random-secret-of-at-least-32-characters
NEXTAUTH_SECRET=replace-with-the-same-random-secret

# Managed PostgreSQL. The schema must be dedicated to Apple333; do not use
# public on a shared database. URL-encode reserved password characters in
# DATABASE_URL.
POSTGRES_DB=apple333
POSTGRES_SCHEMA=apple333
POSTGRES_USER=apple333
# Use a shell-safe secret, for example: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-unique-password
DATABASE_URL=postgresql://apple333:replace-with-a-long-unique-password@postgres:5432/apple333?schema=apple333

# Redis is provisioned for future adapters. It is not exposed to the host.
REDIS_URL=redis://redis:6379

# Optional observability/storage. Leave unset when not configured.
SENTRY_DSN=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
