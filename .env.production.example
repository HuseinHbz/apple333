# Apple333 bare-metal PM2 production configuration.
# Copy to .env.production, replace every placeholder through your secret
# manager, then set mode 0600. This file is intentionally ignored by Git.

NODE_ENV=production
APPLE333_RUNTIME_ENVIRONMENT=production
PORT=3000
HOSTNAME=127.0.0.1
APP_NAME=Apple333
APP_URL=https://apple333.ir

# Use a dedicated, approved PostgreSQL database/schema. Never paste a real
# password into Git, tickets, logs, or shell history.
DATABASE_URL=postgresql://apple333:REPLACE_WITH_SECRET@127.0.0.1:5432/apple333?schema=public

# Generate distinct high-entropy values (at least 32 characters). Auth.js v4
# compatibility aliases are required by the production deployment policy.
AUTH_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
AUTH_URL=https://apple333.ir
NEXTAUTH_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
NEXTAUTH_URL=https://apple333.ir

# Redis is mandatory for the production application environment.
REDIS_URL=redis://:REPLACE_WITH_SECRET@127.0.0.1:6379

# Deployment-only, non-secret settings. Pin this to a reviewed remote branch;
# the update script uses fetch + fast-forward only and never resets local work.
APPLE333_DEPLOY_BRANCH=feature/deployment-production-fix
APPLE333_GIT_REMOTE=origin
APPLE333_PM2_LOG_DIR=/var/log/apple333
APPLE333_PM2_BACKUP_DIR=/var/backups/apple333
# Set this only when the PM2 daemon intentionally uses a non-default home.
APPLE333_PM2_HOME=
APPLE333_PM2_INSTANCES=max
