# Local/disposable PIM database only. Copy to .env.pim-test; never commit it.
# The preflight validates the opt-in, URL, role, database, schema, loopback host,
# and non-default test port without opening a network connection.
NODE_ENV=test
APPLE333_PIM_TEST_DB=1

# These values are intentionally fixed. Do not point this file to a shared,
# staging, or production database, role, hostname, or port.
PIM_TEST_POSTGRES_DB=apple333_pim_test
PIM_TEST_POSTGRES_USER=apple333_pim_test
PIM_TEST_POSTGRES_PASSWORD=local-test-only-change-me
PIM_TEST_POSTGRES_BIND=127.0.0.1
PIM_TEST_POSTGRES_PORT=55432

# Must exactly target the database and role above through a loopback host on
# port 55432 with schema=public. Encode any reserved password characters.
PIM_TEST_DATABASE_URL=postgresql://apple333_pim_test:local-test-only-change-me@127.0.0.1:55432/apple333_pim_test?schema=public
