generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SettingCategory {
  GENERAL
  SECURITY
  NOTIFICATION
  STORAGE
  APPLICATION
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
}

enum NotificationChannel {
  INTERNAL
  EMAIL
  SMS
  PUSH
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum CatalogProductStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum BrandStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductSkuStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum ProductAttributeValueType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
  DIMENSION
}

enum ProductSpecificationScope {
  PRODUCT
  VARIANT
}

enum ProductImportFormat {
  CSV
  XLSX
}

enum ProductImportStatus {
  UPLOADED
  VALIDATING
  READY
  APPLYING
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum ProductImportRowAction {
  CREATE
  UPDATE
  SKIP
}

enum ProductImportRowStatus {
  PENDING
  VALID
  VALIDATION_ERROR
  APPLIED
  FAILED
  ROLLED_BACK
}

enum ProductMediaRole {
  HERO
  GALLERY
  VIDEO
}

enum BranchKind {
  STORE
  CENTRAL_STOCK
}

enum StorefrontCartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
}

model User {
  id              String                 @id @default(cuid())
  name            String?
  image           String?
  email           String?                @unique
  emailVerified   DateTime?
  mobile          String?                @unique
  status          UserStatus             @default(ACTIVE)
  profile         UserProfile?
  adminProfile    AdminUser?
  addresses       Address[]
  roles           UserRole[]
  sessions        Session[]
  accounts        Account[]
  auditLogs       AuditLog[]             @relation("AuditActor")
  uploadedMedia   MediaFile[]            @relation("MediaUploader")
  notifications   Notification[]         @relation("NotificationRecipient")
  updatedSettings SystemSetting[]        @relation("SettingUpdatedBy")
  settingVersions SystemSettingVersion[] @relation("SettingVersionActor")
  storefrontCarts StorefrontCart[]
  approvedProducts CatalogProduct[]       @relation("ProductApprovedBy")
  productWorkflowEvents ProductWorkflowEvent[] @relation("ProductWorkflowActor")
  productImportBatches ProductImportBatch[] @relation("ProductImportRequestedBy")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([status, createdAt])
}

model AdminUser {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String?
  branchId     String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([branchId, isActive])
}

model UserProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  firstName        String?
  lastName         String?
  nationalCodeHash String?  @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  label         String?
  recipientName String
  mobile        String
  province      String?
  city          String?
  line1         String
  postalCode    String?
  isDefault     Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt])
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([isSystem, name])
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  group       String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([group, code])
}

model UserRole {
  userId     String
  roleId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, expires])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}

model SystemSetting {
  id          String                 @id @default(cuid())
  key         String                 @unique
  category    SettingCategory
  value       Json
  isSensitive Boolean                @default(false)
  version     Int                    @default(1)
  updatedById String?
  updatedBy   User?                  @relation("SettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  versions    SystemSettingVersion[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([category, key])
}

model SystemSettingVersion {
  id          String        @id @default(cuid())
  settingId   String
  version     Int
  value       Json
  changedById String?
  setting     SystemSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  changedBy   User?         @relation("SettingVersionActor", fields: [changedById], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())

  @@unique([settingId, version])
  @@index([changedById, createdAt])
}

model MediaFile {
  id           String    @id @default(cuid())
  storageKey   String    @unique
  originalName String
  contentType  String
  extension    String
  bytes        Int
  kind         MediaKind
  url          String?
  checksum     String?
  metadata     Json?
  uploadedById String
  uploadedBy   User      @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  productMedia ProductMedia[]
  brandLogos   Brand[]   @relation("BrandLogoMedia")
  categoryImages CatalogCategory[] @relation("CategoryImageMedia")
  importSourceFiles ProductImportBatch[] @relation("ProductImportSourceFile")
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([uploadedById, createdAt])
  @@index([kind, deletedAt, createdAt])
}

model CatalogCategory {
  id                  String                       @id @default(cuid())
  parentId            String?
  imageMediaId        String?
  slug                String                       @unique
  name                String
  description         String?
  imageUrl            String?
  seoTitle            String?
  seoDescription      String?
  canonicalUrl        String?
  schemaData          Json?
  sortOrder           Int                          @default(0)
  isActive            Boolean                      @default(true)
  deletedAt           DateTime?
  parent              CatalogCategory?             @relation("CatalogCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children            CatalogCategory[]            @relation("CatalogCategoryTree")
  imageMedia          MediaFile?                   @relation("CategoryImageMedia", fields: [imageMediaId], references: [id], onDelete: SetNull)
  products            CatalogProduct[]
  attributeAssignments CategoryAttribute[]
  specificationGroups CategorySpecificationGroup[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
  @@index([deletedAt, isActive])
}

model CatalogProduct {
  id                  String               @id @default(cuid())
  categoryId          String?
  brandId             String?
  approvedById        String?
  slug                String               @unique
  name                String
  brand               String               @default("Apple")
  summary             String?
  description         String?
  status              CatalogProductStatus @default(DRAFT)
  specifications      Json?
  seoTitle            String?
  seoDescription      String?
  submittedForReviewAt DateTime?
  approvedAt          DateTime?
  publishedAt         DateTime?
  deletedAt           DateTime?
  version             Int                  @default(1)
  searchText          String?
  isFeatured          Boolean              @default(false)
  featuredRank        Int?
  isNew               Boolean              @default(false)
  isOnSale            Boolean              @default(false)
  category            CatalogCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandRecord         Brand?                @relation(fields: [brandId], references: [id], onDelete: SetNull)
  approvedBy          User?                 @relation("ProductApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  variants            CatalogVariant[]
  media               ProductMedia[]
  seo                 ProductSeo?
  specificationsStructured ProductSpecification[]
  workflowEvents      ProductWorkflowEvent[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@index([isFeatured, status])
  @@index([brandId, status, publishedAt])
  @@index([deletedAt, status, updatedAt])
}

model CatalogVariant {
  id                  String               @id @default(cuid())
  productId           String
  warrantyId          String?
  sku                 String               @unique
  title               String?
  color               String?
  storage             String?
  region              String?
  modelNumber         String?
  optionKey           String?
  warranty            String?
  attributes          Json?
  priceRials          BigInt
  compareAtPriceRials BigInt?
  isActive            Boolean              @default(true)
  deletedAt           DateTime?
  version             Int                  @default(1)
  sortOrder           Int                  @default(0)
  product             CatalogProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  warrantyRecord      Warranty?            @relation(fields: [warrantyId], references: [id], onDelete: SetNull)
  inventory           BranchInventory[]
  cartItems           StorefrontCartItem[]
  skuRecord           ProductSku?
  specificationsStructured ProductSpecification[]
  media               ProductMedia[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([productId, isActive, sortOrder])
  @@index([isActive, priceRials])
  @@index([warrantyId, isActive])
  @@index([productId, optionKey])
  @@index([deletedAt, isActive])
}

model ProductMedia {
  productId String
  mediaId   String
  variantId String?
  id        String           @default(cuid()) @unique
  role      ProductMediaRole @default(GALLERY)
  altText   String?
  caption   String?
  sortOrder Int              @default(0)
  product   CatalogProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   CatalogVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  media     MediaFile        @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@id([productId, mediaId])
  @@index([mediaId])
  @@index([productId, role, sortOrder])
  @@index([variantId, sortOrder])
}

model Brand {
  id             String      @id @default(cuid())
  code           String      @unique
  slug           String      @unique
  name           String
  logoMediaId    String?
  description    String?
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  schemaData     Json?
  status         BrandStatus @default(DRAFT)
  deletedAt      DateTime?
  logoMedia      MediaFile?  @relation("BrandLogoMedia", fields: [logoMediaId], references: [id], onDelete: SetNull)
  products       CatalogProduct[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status, name])
  @@index([deletedAt, status])
}

model Warranty {
  id             String   @id @default(cuid())
  code           String   @unique
  provider        String
  name           String
  durationMonths Int
  terms          String?  @db.Text
  conditions     String?  @db.Text
  isActive       Boolean  @default(true)
  deletedAt      DateTime?
  variants       CatalogVariant[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([provider, isActive])
  @@index([deletedAt, isActive])
}

model ProductSku {
  id                  String           @id @default(cuid())
  variantId           String           @unique
  code                String           @unique
  barcode             String?          @unique
  priceRials          BigInt
  compareAtPriceRials BigInt?
  costRials           BigInt?
  status              ProductSkuStatus @default(ACTIVE)
  version             Int              @default(1)
  deletedAt           DateTime?
  variant             CatalogVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([status, updatedAt])
  @@index([deletedAt, status])
}

model SpecificationGroup {
  id          String             @id @default(cuid())
  code        String             @unique
  name        String
  description String?
  sortOrder   Int                @default(0)
  isActive    Boolean            @default(true)
  deletedAt   DateTime?
  attributes  ProductAttribute[]
  categories  CategorySpecificationGroup[]
  categoryAttributes CategoryAttribute[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([isActive, sortOrder])
  @@index([deletedAt, isActive])
}

model ProductAttribute {
  id          String                    @id @default(cuid())
  groupId     String?
  code        String                    @unique
  name        String
  valueType   ProductAttributeValueType
  unitCode    String?
  description String?
  isFilterable Boolean                  @default(false)
  isSearchable Boolean                  @default(true)
  isRequiredDefault Boolean             @default(false)
  sortOrder   Int                       @default(0)
  isActive    Boolean                   @default(true)
  deletedAt   DateTime?
  group       SpecificationGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  values      AttributeValue[]
  categoryAssignments CategoryAttribute[]
  specifications ProductSpecification[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([groupId, isActive, sortOrder])
  @@index([deletedAt, isActive])
}

model AttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  code        String
  label       String
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  metadata    Json?
  deletedAt   DateTime?
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  specifications ProductSpecification[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([attributeId, code])
  @@index([attributeId, isActive, sortOrder])
  @@index([deletedAt, isActive])
}

model CategorySpecificationGroup {
  id         String             @id @default(cuid())
  categoryId String
  groupId    String
  sortOrder  Int                @default(0)
  category   CatalogCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group      SpecificationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([categoryId, groupId])
  @@index([groupId, sortOrder])
}

model CategoryAttribute {
  id          String             @id @default(cuid())
  categoryId  String
  attributeId String
  groupId     String?
  isRequired  Boolean            @default(false)
  isFilterable Boolean            @default(false)
  sortOrder   Int                @default(0)
  category    CatalogCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute   @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  group       SpecificationGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([categoryId, attributeId])
  @@index([groupId, sortOrder])
}

model ProductSpecification {
  id               String                    @id @default(cuid())
  productId        String
  variantId        String?
  attributeId      String
  attributeValueId String?
  scope            ProductSpecificationScope
  subjectKey       String
  value            Json?
  displayValue     String
  unitCode         String?
  sortOrder        Int                       @default(0)
  product          CatalogProduct            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant          CatalogVariant?           @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute        ProductAttribute          @relation(fields: [attributeId], references: [id], onDelete: Restrict)
  attributeValue   AttributeValue?           @relation(fields: [attributeValueId], references: [id], onDelete: SetNull)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@unique([productId, subjectKey, attributeId])
  @@index([variantId, sortOrder])
  @@index([attributeId, attributeValueId])
}

model ProductSeo {
  id              String         @id @default(cuid())
  productId       String         @unique
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  schemaData      Json?
  noIndex         Boolean        @default(false)
  product         CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ProductWorkflowEvent {
  id         String               @id @default(cuid())
  productId  String
  actorId    String?
  fromStatus CatalogProductStatus
  toStatus   CatalogProductStatus
  note       String?
  revision   Int
  product    CatalogProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  actor      User?                @relation("ProductWorkflowActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([productId, createdAt])
  @@index([actorId, createdAt])
}

model ProductImportBatch {
  id                String              @id @default(cuid())
  sourceFileId      String?
  requestedById     String?
  format            ProductImportFormat
  status            ProductImportStatus @default(UPLOADED)
  originalFileName  String
  sourceChecksum    String?
  mappingVersion    String              @default("v1")
  totalRows         Int                 @default(0)
  validRows         Int                 @default(0)
  failedRows        Int                 @default(0)
  validationSummary Json?
  errorReport       Json?
  appliedAt         DateTime?
  rolledBackAt      DateTime?
  sourceFile        MediaFile?          @relation("ProductImportSourceFile", fields: [sourceFileId], references: [id], onDelete: SetNull)
  requestedBy       User?               @relation("ProductImportRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  rows              ProductImportRow[]
  changes           ProductImportChange[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([requestedById, createdAt])
  @@index([sourceChecksum])
}

model ProductImportRow {
  id               String                 @id @default(cuid())
  importBatchId    String
  rowNumber        Int
  status           ProductImportRowStatus @default(PENDING)
  action           ProductImportRowAction @default(SKIP)
  rawData          Json
  normalizedData   Json?
  validationErrors Json?
  appliedAt        DateTime?
  importBatch      ProductImportBatch     @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@unique([importBatchId, rowNumber])
  @@index([importBatchId, status, rowNumber])
}

model ProductImportChange {
  id             String             @id @default(cuid())
  importBatchId  String
  entityType     String
  entityId       String
  action         ProductImportRowAction
  beforeSnapshot Json?
  afterSnapshot  Json?
  importBatch    ProductImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([importBatchId, entityType])
}

model Branch {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  kind        BranchKind        @default(STORE)
  city        String?
  address     String?
  phone       String?
  isActive    Boolean           @default(true)
  isPickupEnabled Boolean        @default(true)
  inventory   BranchInventory[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([isActive, kind])
}

model BranchInventory {
  branchId  String
  variantId String
  onHand    Int            @default(0)
  reserved  Int            @default(0)
  branch    Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant   CatalogVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  updatedAt DateTime       @updatedAt

  @@id([branchId, variantId])
  @@index([variantId])
}

model StorefrontCart {
  id             String               @id @default(cuid())
  userId         String?
  guestTokenHash String?              @unique
  status         StorefrontCartStatus @default(ACTIVE)
  currency       String               @default("IRR")
  version        Int                  @default(1)
  expiresAt      DateTime?
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  items          StorefrontCartItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([userId, status, updatedAt])
  @@index([status, expiresAt])
}

model StorefrontCartItem {
  cartId    String
  variantId String
  quantity  Int            @default(1)
  cart      StorefrontCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   CatalogVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@id([cartId, variantId])
  @@index([variantId])
}

model Notification {
  id          String               @id @default(cuid())
  recipientId String
  channel     NotificationChannel  @default(INTERNAL)
  priority    NotificationPriority @default(NORMAL)
  status      NotificationStatus   @default(PENDING)
  category    String
  title       String
  body        String
  actionUrl   String?
  metadata    Json?
  readAt      DateTime?
  recipient   User                 @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([recipientId, status, createdAt])
  @@index([category, priority, createdAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  requestId  String
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  actor      User?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, entityType, createdAt])
  @@index([requestId])
}
