{
  "name": "apple333-enterprise-platform",
  "version": "2.0.0-alpha.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prepare:standalone": "node scripts/prepare-standalone-runtime.mjs",
