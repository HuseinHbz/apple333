    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "15.5.18",
    "next-auth": "^4.24.14",
    "prom-client": "15.1.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "redis": "4.7.0",
    "zod": "3.24.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "3.3.1",
    "@playwright/test": "1.55.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "ajv": "8.20.0",
    "autoprefixer": "10.4.21",
    "eslint": "9.25.1",
    "eslint-config-next": "15.5.18",
    "jsdom": "26.1.0",
    "lighthouse": "^12.8.2",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "prisma": "6.7.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vitest": "3.1.2"
