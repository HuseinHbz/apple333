    "test:pim-db": "node scripts/run-pim-database-tests.mjs",
    "pim:benchmark": "node scripts/benchmark-pim-catalog.mjs",
    "inventory:test:preflight": "node scripts/verify-inventory-test-environment.mjs",
    "inventory:test:migrate": "node scripts/run-inventory-test-migrations.mjs",
    "test:inventory-db": "node scripts/run-inventory-database-tests.mjs",
    "inventory:e2e:seed": "node scripts/seed-e2e-inventory.mjs",
    "test:e2e:inventory": "node scripts/run-inventory-e2e-tests.mjs",
    "inventory:benchmark": "node scripts/benchmark-inventory.mjs --help",
    "typecheck:phase-06-tests": "tsc --project tsconfig.phase06-tests.json",
    "prompt:validate": "tsc --project tsconfig.prompt-validator.json && node .prompt-validator/scripts/validate-enterprise-prompts.js",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
